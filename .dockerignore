# Exclude dependency directories
node_modules/
.next/
out/
build/
dist/

# Exclude IDE and tool directories
.git/
.gitignore
.vercel/
.opencode/
.github/

# Exclude local environment files containing secrets
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Exclude logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Exclude OS generated files
.DS_Store
Thumbs.db
