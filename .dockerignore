# Exclude dependency directories
node_modules/
.next/
out/
build/
dist/

# Exclude IDE and tool directories
.git/
.gitignore
.vercel/
.opencode/
.github/

# Exclude local environment files containing secrets.
# docker-compose reads .env.docker directly; it should never enter the image context.
.env*

# Exclude logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Exclude OS generated files
.DS_Store
Thumbs.db

# Exclude local docs and helper scripts from the Docker build context
DOCKER.md
README.md
ARCHITECTURE.md
STRUCTURE.md
docker-setup.ps1
docker-setup.sh
AGENTS.md
SKILL.md
botnet.png
botnet-admin.png
tests/
tsconfig.test.json
coverage/
.test-dist/
supabase/.temp/
