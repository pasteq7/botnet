{
  "name": "botnet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -k -p \"[{name}]\" -n \"next,inngest\" -c \"blue,green\" \"next dev\" \"inngest dev\"",
    "build": "next build",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "validate": "npm run lint && npm run test && npm run build",
    "start": "next start",
    "lint": "eslint",
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "framer-motion": "^12.38.0",
    "inngest": "^3.54.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "depcheck": {
    "ignoreMatches": [
      "@tailwindcss/postcss",
      "tailwindcss",
      "inngest-cli"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "inngest-cli": "^1.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
