# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# One-time first-admin setup key for production /setup (not required in local development)
SETUP_SECRET=

# Encryption for stored provider API keys (required; generated by npm run setup)
ENCRYPTION_KEY=

# Inngest
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Public site URL for robots.txt and sitemap.xml
NEXT_PUBLIC_SITE_URL=
