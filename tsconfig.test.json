{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "lib/auth/admin-role.ts",
    "lib/ai/autofill-prompts.ts",
    "lib/community-fields.ts",
    "lib/ai/prompts.ts",
    "lib/ai/provider-errors.ts",
    "lib/ai/reliability.ts",
    "lib/ai/source-diversity.ts",
    "lib/inngest/log-id.ts",
    "lib/inngest/step-output.ts",
    "types/index.ts",
    "tests/**/*.test.ts"
  ]
}
